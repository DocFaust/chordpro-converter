{
  "name": "chordpro-converter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . -f checkstyle -o reports/eslint/eslint-checkstyle.xml",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest",
    "sonar": "sonar",
    "test:ci": "vitest run --config vitest.config.js",
    "owasp": "owasp-dependency-check --project chordpro-converter -f ALL -s . --out ./dependency-check-report --disableAssembly --disableYarnAudit --disableOssIndex --disableCentral --data ./dc-data --nvdApiKey $NVDAPIKEY",
    "lint:ci": "eslint . -f checkstyle -o reports/eslint/eslint-checkstyle.xml",
    "lint:sonar": "eslint src --ext .ts,.tsx,.js,.jsx -f json -o reports/eslint/eslint-sonar.json"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
    "dotenv": "^17.4.2",
    "react": "^19.2.5",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-formatter-checkstyle": "^9.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "owasp-dependency-check": "^1.0.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
